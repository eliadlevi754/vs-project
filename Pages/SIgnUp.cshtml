@page
@model vs_project.Pages.SIgnUpModel
@{
}

<html>
<head>
    <style>

        h1 {
            margin-top: 100px;
            text-align: center;
            color: white;
        }

        input {
            margin-left: 50%;
            margin-top: 50px;
        }



        button.g {
            margin: 50px auto;
            background-color: #2dba4e;
            color: white;
            border-color: transparent;
        }

        input, button.g {
            display: block;
            margin: 20px auto;
            padding: 10px;
            width: 250px;
            font-size: 16px;
            border-radius: 16px;
        }

        .button.g:hover {
            background: linear-gradient(45deg, #2ede57, #2dba4e);
            transition-duration: 0.4s;
            transform: scale(1.1)
        }

    </style>
</head>
<body>
    <h1>
        Sign Up
    </h1>

    <form method="post">

        @if (!string.IsNullOrEmpty(Model.msg))
        {
            <h6 class="error-message">@Model.msg</h6>
        }

        <input type="text" id="username" name="username" placeholder="Enter new username" required>
        <input type="password" id="password" name="password" placeholder="Enter new password" required>
        <input type="text" id="Pname" name="Pname" placeholder="Enter first name" required>
        <input type="text" id="Fname" name="Fname" placeholder="Enter last name" required>
        <button type="submit" class="button g">Sign Up</button>
    </form>
</body>
</html>
