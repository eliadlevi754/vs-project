<!DOCTYPE html>
<html lang="en">
@{
    var sessionValue = Context.Session.GetString("username");
    var FirstName = Context.Session.GetString("Fname");
    var SessionAdmin = Context.Session.GetString("admin");
    var SessionFirst = Context.Session.GetString("admin");
}
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - vs_project</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/vs_project.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/contactus.css" />
    @RenderSection("Styles", required: false)

</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                
                <a class="navbar-brand" asp-area="" asp-page="/Index">vs_project</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/contact">Contact Us</a>
                        </li>
                        <div class="dropdown d-inline-flex justify-content-around">
                            <a class="btn  dropdown-toggle text-dark " href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false"> Login</a>
                            <ul class="dropdown-menu">
                                <li><a class="nav-link text-dark" asp-area="" asp-page="/log in">log in</a></li>
                                <li><a class="nav-link text-dark" asp-area="" asp-page="/SIgnUp">Sign up</a></li>
                                <li><a class="nav-link text-dark" href="https://www.youtube.com/watch?v=dQw4w9WgXcQ">Exit</a></li>
                            </ul>
                        </div>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/about us">about us</a>
                        </li>
                        <div class="dropdown d-inline-flex justify-content-around">
                            <a class="btn  dropdown-toggle text-dark " href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false"> Products</a>
                            <ul class="dropdown-menu">
                                <li><a class="nav-link text-dark" asp-area="" asp-page="/product1">product 1</a></li>
                                <li><a class="nav-link text-dark" asp-area="" asp-page="/product2">product 2</a></li>
                                <li><a class="nav-link text-dark" asp-area="" asp-page="/product3">product 3</a></li>
                                <li><a class="nav-link text-dark" asp-area="" asp-page="/product4">product 4</a></li>
                            </ul>
                        </div>
                        <li><a class="nav-link text-dark" asp-area="" asp-page="/employees">employees</a></li>

                    </ul>
                    
                </div>
                
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
