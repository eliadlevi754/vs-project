@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}
<html>
    <head>
        <style>
            h1{
                color: white;
                text-align: center;
            }
            .button{
                background-color: #00BFFF;
                border: none;
                color: white;
                padding: 32px 64px;
                text-align: center;
                text-decoration: none;
                display: inline-block;
                font-size: 32px;
                font-weight:bold;
                margin: 4px 2px;
                transition-duration: 0.4s;
                cursor: pointer;
                border-radius: 32px;
            }
            .button:hover{
                transform: scale(1.1);
                background: linear-gradient(45deg, aqua, #00BFFF);
                box-shadow: 0px 4px 12px rgba(0, 0, 0, 0.3);
            }

            .button-container {
                display: flex;
                flex-direction:column;
                justify-content: center;
                gap: 50px;
                margin-top: 40px;
            }

        </style>
    </head>
    <body>
        <h1>Welcome to AiForce. Where boredom leads to innovations.</h1>
        <div class="button-container">
        <button class="button gadget" onclick="location.href='products'">Explore Our Gadgets</button>
        <button class="button about" onclick="location.href='about us'">About Us</button>
        <button class="button contact" onclick="location.href='Contact'">Contact Us</button>
        </div>
    </body>
</html>