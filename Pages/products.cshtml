@page
@model vs_project.Pages.productsModel
@{
}
<head>
    <style>
        h1 {
            text-align: center;
        }

        .button {
            background-color: #00BFFF;
            border: none;
            color: white;
            padding: 32px 64px;
            text-align: center;
            text-decoration: none;
            display: inline-block;
            font-size: 32px;
            font-weight: bold;
            margin: 4px 2px;
            transition-duration: 0.4s;
            cursor: pointer;
            border-radius: 32px;
        }

            .button:hover {
                transform: scale(1.1);
                background: linear-gradient(45deg, aqua, #00BFFF);
                box-shadow: 0px 4px 12px rgba(0, 0, 0, 0.3);
            }

        .button-container {
            display: flex;
            flex-direction: column;
            justify-content: center;
            gap: 50px;
            margin-top: 40px;
        }
    </style>
</head>
<body>
    <h1>
        our products:
    </h1>
    <button class="button gadget" onclick="location.href='product1'">product 1</button>
    <button class="button about" onclick="location.href='product2'">product 2</button>
    <button class="button contact" onclick="location.href='product3'">product 3</button>
    <button class="button contact" onclick="location.href='product4'">product 4</button>
</body>