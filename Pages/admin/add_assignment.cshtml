@page
@model vs_project.Pages.admin.add_assignmentModel
@{
}
<div class="container mt-5">
    <div class="card shadow p-4">
        <h2 class="text-primary mb-4">Add New Assignment</h2>
        
        <form method="post" enctype="multipart/form-data">
            <div class="mb-3">
                <label class="form-label">Assignment Title</label>
                <input type="text" name="Title" class="form-control" placeholder="" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Instructions / Text</label>
                <textarea name="Description" class="form-control" rows="5" placeholder=""></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label">Upload File (PDF/Word/Image)</label>
                <input type="file" name="Upload" class="form-control" />
            </div>

            <button type="submit" class="btn btn-success btn-lg w-100">Upload</button>
            <div class="mb-3">
                <label class="form-label">Target Class</label>
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="Subject" value="math" checked>
                    <label class="form-check-label">Mathematics</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="Subject" value="physics">
                    <label class="form-check-label">Physics</label>
                </div>
            </div>
        </form>
    </div>
</div>