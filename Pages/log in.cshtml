@page
@model vs_project.Pages.log_inModel
@{
}
<html>
    <head>
        <style>
             
             h1 {
                 margin-top: 200px;
                 text-align:center;
                 color: white;
             }
             input {
                 margin-left: 50%;
                 margin-top: 50px;
             }
             input[type="button"]{
                 padding-left: 180px;
                 
             }
             button.g{
                 margin: 50px auto;
                 background-color: #2dba4e;
                 color: white;
                 border-color: transparent;
             }
             input, button.g{
                display: block;
                margin: 20px auto;
                padding: 10px;
                width: 250px; 
                font-size: 16px;
                border-radius: 16px;
             }
             .button.g:hover{
                background: linear-gradient(45deg, #2ede57, #2dba4e);
                 transition-duration:0.4s;
                 transform:scale(1.1)
                 
             }

        </style>
    </head>
    <body>
        <h1>
            Log in
        </h1>

    <form method="post">
        <input type="text" id="username" name="UserName" placeholder="Enter your username" required>
        <input type="password" id="password" name="Password" placeholder="Enter your password" required>
        @{
            if (Model.msg == "Wrong username or password")
            {
                <h6 style="color:red; text-align: center;">@Model.msg</h6>
            }
        }
        <button type="submit" class="button g">Log in</button>
    </form>
    @Model.msg
    
    </body>
</html>
